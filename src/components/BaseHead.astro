---
import '../styles/global.css';
import { SITE_TITLE } from '../consts';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	image?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image } = Astro.props;

// OG image: try /og/ path for blog posts, fallback to placeholder or image
const ogPath = Astro.url.pathname.match(/^\/(?:blog\/)?([^/]+)/);
const ogSlug = ogPath ? ogPath[1] : null;
const ogImage = ogSlug && !['', 'blog', 'tags', 'docs', 'search', 'archive', 'about'].includes(ogSlug)
	? new URL(`/og/${ogSlug}`, Astro.site)
	: image
		? new URL(image, Astro.url)
		: new URL('/assets/blog-placeholder-1.jpg', Astro.url);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={new URL('rss.xml', Astro.site)} />
<meta name="generator" content={Astro.generator} />
<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

<Font cssVariable="--font-atkinson" preload />

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="description" content={description} />

<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImage} />

<script is:inline>
	const applyTheme = () => {
		const theme = localStorage.getItem('theme');
		if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
			document.documentElement.classList.add('dark');
			document.documentElement.dataset.theme = 'github-dark';
		} else {
			document.documentElement.classList.remove('dark');
			document.documentElement.dataset.theme = 'github-light';
		}
	};

	// Ejecución inicial al cargar la página
	applyTheme();

	// Aplica el tema al nuevo documento ANTES del swap (evita flash en fade)
	document.addEventListener('astro:before-swap', ({ newDocument }) => {
		const theme = localStorage.getItem('theme');
		if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
			newDocument.documentElement.classList.add('dark');
			newDocument.documentElement.dataset.theme = 'github-dark';
		}
	});
	document.addEventListener('astro:after-swap', applyTheme);
</script>

