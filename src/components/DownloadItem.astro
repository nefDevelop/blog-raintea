---
interface Props {
	label: string;
	url: string;
}
const { label, url } = Astro.props;
---

<a
	href={url}
	target="_blank"
	rel="noopener noreferrer"
	download
	class="group flex items-center justify-between gap-4 rounded-xl border border-[var(--border-light)] bg-[var(--card-bg)] p-4 no-underline transition-all hover:-translate-y-0.5 hover:border-[var(--primary)] hover:shadow-sm hover:shadow-[var(--primary)]/10"
>
	<div class="flex items-center gap-3 min-w-0">
		<svg class="size-5 shrink-0 text-[var(--primary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
			<polyline points="14 2 14 8 20 8" />
			<line x1="16" y1="13" x2="8" y2="13" />
			<line x1="16" y1="17" x2="8" y2="17" />
			<polyline points="10 9 9 9 8 9" />
		</svg>
		<span class="truncate text-sm font-medium text-[var(--text-main)] group-hover:text-[var(--primary)] transition-colors">
			{label}
		</span>
	</div>
	<span class="flex shrink-0 items-center gap-1.5 rounded-lg border border-[var(--border-light)] bg-[var(--bg)] px-3 py-1.5 text-xs font-semibold text-[var(--text-muted)] transition-colors group-hover:border-[var(--primary)] group-hover:bg-[var(--primary)] group-hover:text-white">
		<svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
			<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
			<polyline points="7 10 12 15 17 10" />
			<line x1="12" y1="15" x2="12" y2="3" />
		</svg>
		Descargar
	</span>
</a>
