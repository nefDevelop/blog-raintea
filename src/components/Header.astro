---
import { getCollection } from 'astro:content';
import { SITE_TITLE, ALL_PAGES } from '../consts';
import HeaderLink from './HeaderLink.astro';
import Sun from './icons/Sun.astro';
import Moon from './icons/Moon.astro';
import Menu from './icons/Menu.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const [blogPosts, docPages] = await Promise.all([
	getCollection('blog'),
	getCollection('docs'),
]);
const hasBlog = blogPosts.some((p) => !p.data.draft);
const hasDocs = docPages.length > 0;
const hasAbout = true; // about is a static page, always available

const available: Record<string, boolean> = { blog: hasBlog, docs: hasDocs, about: hasAbout };
const NAV_LINKS = ALL_PAGES.filter((p) => p.requires === null || available[p.requires]);
---

<header
	x-data="{ mobileOpen: false, dark: document.documentElement.classList.contains('dark') }"
	transition:name="header"
	transition:persist
	class="fixed inset-x-0 bottom-0 z-50 border-t border-[var(--border-light)] bg-[var(--card-bg)]/80 backdrop-blur-sm supports-[backdrop-filter]:bg-[var(--card-bg)]/60 md:sticky md:top-0 md:border-t-0 md:border-b"
>
	<!-- Filo de refracción del cristal opaco -->
	<div class="pointer-events-none absolute inset-x-0 top-0 h-[3px] md:top-auto md:bottom-0 backdrop-blur-[24px] backdrop-brightness-[1.15] dark:backdrop-brightness-[1.2] bg-white/[0.02] mix-blend-overlay"></div>



	<div
		id="mobile-menu"
		x-show="mobileOpen"
		@keydown.escape.window="mobileOpen = false"
		x-transition:enter="transition ease-out duration-200"
		x-transition:enter-start="opacity-0 translate-y-2"
		x-transition:enter-end="opacity-100 translate-y-0"
		class="border-b border-[var(--border-light)] bg-[var(--card-bg)] px-4 py-3 md:hidden"
		@click.outside="mobileOpen = false"
	>
		<div class="flex flex-col gap-2">
			{
				NAV_LINKS.map(({ label, url }) => (
					<HeaderLink href={url} class="rounded-md px-3 py-2 text-sm font-medium no-underline" aria-current="page">{t(`nav.${label.toLowerCase()}` as any)}</HeaderLink>
				))
			}
		</div>
	</div>

	<nav aria-label="Main" class="flex w-full items-center justify-between px-4 py-3 md:px-8">
		<a href="/" class="text-lg font-bold tracking-tight no-underline text-[var(--text-main)] hover:text-[var(--primary)]">
			{SITE_TITLE}
		</a>

		<div class="hidden items-center gap-6 md:flex">
			{
				NAV_LINKS.filter((_, i) => i < 3).map(({ label, url }) => (
					<HeaderLink href={url} class="text-sm font-medium no-underline" aria-current="page">{t(`nav.${label.toLowerCase()}` as any)}</HeaderLink>
				))
			}

			{NAV_LINKS.length > 3 && (
				<div x-data="{ open: false }" @click.away="open = false" class="relative">
					<button
						@click="open = !open"
						:aria-expanded="open"
						class="flex items-center gap-1 text-sm font-medium text-[var(--text-muted)] transition-colors hover:text-[var(--text-main)] no-underline"
					>
						{t('action.more')}
						<svg :class="open ? 'rotate-180' : ''" class="size-3 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
					</button>
					<div
						x-show="open"
						x-transition:enter="transition ease-out duration-150"
						x-transition:enter-start="opacity-0 translate-y-1"
						x-transition:enter-end="opacity-100 translate-y-0"
						class="absolute right-0 top-full mt-2 w-44 rounded-xl border border-[var(--border-light)] bg-[var(--card-bg)] p-2 shadow-lg"
					>
						{
							NAV_LINKS.slice(3).map(({ label, url }) => (
								<HeaderLink href={url} class="block rounded-lg px-3 py-2 text-sm font-medium no-underline" aria-current="page">{t(`nav.${label.toLowerCase()}` as any)}</HeaderLink>
							))
						}
					</div>
				</div>
			)}
			
			<button
				@click="window.dispatchEvent(new CustomEvent('open-search'))"
				class="group flex h-8 items-center gap-2 rounded-md border border-[var(--border-light)] bg-[var(--bg)] px-2.5 text-[var(--text-muted)] transition-colors hover:border-[var(--primary)] hover:text-[var(--text-main)]"
				aria-label={t('action.search')}
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-colors group-hover:text-[var(--primary)]"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
				<kbd class="rounded border border-[var(--border-light)] bg-[var(--card-bg)] px-1.5 text-[10px] font-sans font-medium text-[var(--text-muted)] transition-colors group-hover:border-[var(--primary-20)] group-hover:text-[var(--text-main)]">Ctrl+K</kbd>
			</button>
		</div>

		<div class="flex items-center gap-3">
			<button
				@click="window.dispatchEvent(new CustomEvent('open-search'))"
				class="flex size-8 cursor-pointer items-center justify-center rounded-md text-[var(--text-muted)] transition-colors hover:bg-[var(--border-light)] hover:text-[var(--primary)] md:hidden"
				aria-label={t('action.search')}
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
			</button>

			<button
				@click="
					dark = !dark;
					document.documentElement.classList.toggle('dark', dark);
					document.documentElement.dataset.theme = dark ? 'github-dark' : 'github-light';
					localStorage.setItem('theme', dark ? 'dark' : 'light')
				"
				:aria-pressed="dark"
				class="flex size-8 cursor-pointer items-center justify-center rounded-md text-[var(--text-muted)] hover:bg-[var(--border-light)] hover:text-[var(--text-main)]"
				aria-label="Toggle dark mode"
			>
				<span aria-live="polite" class="sr-only" x-text="dark ? 'Dark mode enabled' : 'Light mode enabled'"></span>
				<Moon class="dark:hidden" />
				<Sun class="hidden dark:inline" />
			</button>

			<button
				x-on:click="mobileOpen = !mobileOpen"
				:aria-expanded="mobileOpen"
				aria-controls="mobile-menu"
				class="flex size-8 cursor-pointer items-center justify-center rounded-md text-[var(--text-muted)] hover:bg-[var(--border-light)] hover:text-[var(--text-main)] md:hidden"
				aria-label="Toggle menu"
			>
				<Menu />
			</button>
		</div>
	</nav>
</header>
