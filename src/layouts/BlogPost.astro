---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Giscus from '../components/Giscus.astro';
import PostCard from '../components/PostCard.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import ShareButtons from '../components/ShareButtons.astro';
import Sidebar from '../components/widgets/Sidebar.astro';
import WidgetToc from '../components/widgets/WidgetToc.astro';
import { SIDEBAR_WIDGETS, SITE_TITLE, SITE_URL } from '../consts';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import Layout from './Layout.astro';

type SeriesEntry = {
	id: string;
	data: { title: string };
};

type Props = CollectionEntry<'blog'>['data'] & {
	readingTime?: { text: string };
	prevInSeries?: SeriesEntry | null;
	nextInSeries?: SeriesEntry | null;
	relatedPosts?: any[];
	backlinks?: any[];
	postId?: string;
};

const {
	title, description, published, updated, image,
	tags = [], categories = [], author = [],
	difficulty, readingTime, series, prevInSeries, nextInSeries, relatedPosts = [], backlinks = [], postId,
} = Astro.props;

let seriesInfo: { current: number; total: number; title: string } | null = null;
if (series && postId) {
	const allSeries = await getCollection('series');
	const sData = allSeries.find((s) => s.id === series);
	if (sData) {
		const idx = sData.data.chapters.findIndex((c) => c === postId);
		if (idx !== -1) {
			seriesInfo = { current: idx + 1, total: sData.data.chapters.length, title: sData.data.title };
		}
	}
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={title} description={description}>
	<ReadingProgress />
	<div class="mx-auto max-w-6xl px-4 py-8">
		<div class="flex flex-col gap-8 lg:flex-row">
			<article class="min-w-0 flex-1">
				<script is:inline type="application/ld+json" set:html={JSON.stringify({
					'@context': 'https://schema.org',
					'@type': 'BlogPosting',
					headline: title,
					description,
					datePublished: published,
					...(updated ? { dateModified: updated } : {}),
					author: author.map((a) => ({ '@type': 'Person', name: a })),
					...(image ? { image: { '@type': 'ImageObject', url: new URL(image, SITE_URL).href } } : {}),
					url: Astro.url.href,
					publisher: { '@type': 'Organization', name: SITE_TITLE },
				}).replace(/</g, '\\u003c').replace(/>/g, '\\u003e')}></script>

				{
					image && (
						<div class="mb-8 overflow-hidden rounded-xl">
							<img src={image} alt="" class="size-full object-cover" style="aspect-ratio: 1200/630" loading="lazy" decoding="async" />
						</div>
					)
				}

				<header class="mb-10 max-w-[65ch]">
					
					<h1 class="text-3xl font-bold leading-tight tracking-tight md:text-5xl">{title}</h1>
					<p class="mt-4 text-xl text-[var(--text-muted)] leading-relaxed">{description}</p>
					
					<div class="mt-8 flex flex-wrap items-center justify-between gap-x-6 gap-y-4 border-y border-[var(--border-light)] py-4 text-sm text-[var(--text-muted)]">
						<div class="flex flex-wrap items-center gap-x-6 gap-y-3">
							{author.length > 0 && (
								<div class="flex items-center gap-2 font-medium text-[var(--text-main)]">
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--primary)]"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
									{author.map((a, i) => (
										<><a href={`/authors/${a}/`} class="text-[var(--text-main)] transition-colors hover:text-[var(--primary)] no-underline">{a}</a>{i < author.length - 1 ? ', ' : ''}</>
									))}
								</div>
							)}
							{readingTime?.text && (
								<div class="flex items-center gap-2">
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
									<span>{readingTime.text}</span>
								</div>
							)}
						</div>
						
						<div class="flex flex-wrap items-center gap-x-6 gap-y-3 sm:text-right">
							{updated && (
								<div class="flex items-center gap-2 text-[13px] italic">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70"><path d="M3 2v6h6"/><path d="M3 13a9 9 0 1 0 3-7.7L3 8"/></svg>
									<span>{t('blog.updated')} <FormattedDate date={updated} /></span>
								</div>
							)}
							<div class="flex items-center gap-2">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
								<FormattedDate date={published} />
							</div>
						</div>
					</div>
				</header>

				<div class="prose">
					<slot />
				</div>

				<div class="max-w-[65ch]">
				{(categories.length > 0 || difficulty || tags.length > 0) && (
					<div class="mb-8 mt-12 border-t border-[var(--border-light)] pt-8">
						<h3 class="mb-4 text-xs font-bold uppercase tracking-widest text-[var(--text-muted)]">{t('blog.related')}</h3>
						<div class="flex flex-wrap items-center gap-2.5">
							{categories.map((cat) => (
								<a href={`/categories/${cat}/`} class="rounded bg-[var(--primary-10)] px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wider text-[var(--primary)] no-underline transition-colors hover:bg-[var(--primary)] hover:text-white">
									{cat}
								</a>
							))}
							{difficulty && (
								<span class="flex items-center gap-1 rounded border border-[var(--secondary)] bg-[var(--secondary-10)] px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wider text-[var(--secondary)]">
									<svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
									{difficulty}
								</span>
							)}
							{tags.map((tag) => (
								<div class="flex items-center rounded border border-[var(--border-light)] bg-[var(--card-bg)] px-2.5 py-1 text-[12px] font-medium text-[var(--text-muted)] transition-colors hover:border-[var(--tertiary)] hover:text-[var(--tertiary)]">
									<span class="mr-0.5 opacity-50">#</span>
									{tag.split('/').map((part, index, arr) => {
										const path = arr.slice(0, index + 1).join('/');
										return (
											<div class="flex items-center">
												<a href={`/tags/${path}/`} class="no-underline transition-colors hover:text-[var(--tertiary)]">
													{part}
												</a>
												{index < arr.length - 1 && <span class="mx-0.5 opacity-50">/</span>}
											</div>
										);
									})}
								</div>
							))}
						</div>
					</div>
				)}

				{seriesInfo && (
					<div class="mb-6">
						<a href={`/series/${series}/`} class="inline-flex items-center gap-2 rounded border border-[var(--primary-20)] bg-[var(--primary-10)] px-3 py-1.5 text-xs font-semibold text-[var(--primary)] no-underline transition-colors hover:bg-[var(--primary)] hover:text-white">
							<svg class="size-4 fill-none stroke-current stroke-2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
							{seriesInfo.title} <span class="ml-1 font-normal opacity-80">— {t('blog.series.part')} {seriesInfo.current} {t('blog.series.of')} {seriesInfo.total}</span>
						</a>
					</div>
				)}

					{series && (prevInSeries || nextInSeries) && (
					<div class="mt-8 rounded-xl border border-[var(--border-light)] bg-[var(--card-bg)] p-5">
						<p class="mb-3 text-xs font-bold uppercase tracking-widest text-[var(--text-muted)]">{seriesInfo?.title || series}</p>
						<div class="flex flex-col gap-2 sm:flex-row sm:justify-between">
							{prevInSeries ? (
								<a href={`/blog/${prevInSeries.id}/`} aria-label={`Previous in series: ${prevInSeries.data.title}`} class="flex items-center gap-2 text-sm text-[var(--text-muted)] no-underline hover:text-[var(--primary)]">
									<svg class="size-4 fill-none stroke-current stroke-2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
									<span>{prevInSeries.data.title}</span>
								</a>
							) : <div />}
							{nextInSeries ? (
								<a href={`/blog/${nextInSeries.id}/`} aria-label={`Next in series: ${nextInSeries.data.title}`} class="flex items-center gap-2 text-sm text-[var(--text-muted)] no-underline hover:text-[var(--primary)] sm:text-right">
									<span>{nextInSeries.data.title}</span>
									<svg class="size-4 fill-none stroke-current stroke-2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
								</a>
							) : <div />}
						</div>
					</div>
				)}

				<ShareButtons title={title} />

				{relatedPosts.length > 0 && (
					<section class="mt-12">
						<h2 class="mb-4 text-xl font-bold">Related posts</h2>
						<div class="grid gap-4 sm:grid-cols-3">
							{relatedPosts.map((p) => {
								const words = (p.body || '').split(/\s+/g).filter(Boolean).length;
								const rt = `${Math.max(1, Math.ceil(words / 200))} min read`;
								return (
									<PostCard
										id={p.id}
										title={p.data.title}
										description={p.data.description}
										published={p.data.published}
										image={p.data.image}
										tags={p.data.tags}
										categories={p.data.categories}
										author={p.data.author}
										difficulty={p.data.difficulty}
										pinned={p.data.pinned}
										readingTime={rt}
									/>
								);
							})}
						</div>
					</section>
				)}

				{backlinks.length > 0 && (
					<section class="mt-8">
						<h2 class="mb-3 text-xl font-bold">Backlinks</h2>
						<div class="space-y-2">
							{backlinks.map((p) => (
								<a href={`/blog/${p.id}/`} class="block rounded-lg border border-[var(--border-light)] bg-[var(--card-bg)] p-3 no-underline transition-shadow hover:shadow-sm">
									<p class="text-sm font-medium text-[var(--text-main)] hover:text-[var(--primary)]">{p.data.title}</p>
									<p class="mt-0.5 text-xs text-[var(--text-muted)]">{p.data.description}</p>
								</a>
							))}
						</div>
					</section>
				)}

				<Giscus />
				</div>
			</article>

			<aside class="w-full shrink-0 lg:w-56 lg:block" aria-label="Blog sidebar">
				<div class="lg:sticky lg:top-24 max-h-[calc(100vh-6rem)] overflow-y-auto space-y-6 rounded-xl border border-[var(--border-light)] bg-[var(--card-bg)] p-4 shadow-sm">
					<Sidebar widgets={SIDEBAR_WIDGETS.post} authorSlug={author[0]} seriesName={series} currentSlug={postId} />
				</div>
			</aside>
		</div>
	</div>

	<!-- FAB and Modal TOC (Mobile) -->
	<div slot="fab" x-data="{ tocOpen: false }" class="lg:hidden">
		<!-- Botón Flotante -->
		<button 
			@click="tocOpen = true" 
			class="pointer-events-auto flex size-12 items-center justify-center rounded-full bg-[var(--primary)] text-white shadow-[0_4px_12px_rgba(0,0,0,0.3)] transition-transform hover:scale-105 active:scale-95"
			aria-label="Tabla de Contenidos"
		>
			<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
		</button>

		<!-- Overlay de fondo -->
		<div 
			x-show="tocOpen" 
			x-transition.opacity 
			class="pointer-events-auto fixed inset-0 z-[60] bg-black/60 backdrop-blur-sm"
			@click="tocOpen = false"
			x-cloak
		></div>
		
		<!-- Drawer / Panel inferior -->
		<div 
			x-show="tocOpen" 
			x-transition:enter="transition ease-out duration-300"
			x-transition:enter-start="translate-y-full"
			x-transition:enter-end="translate-y-0"
			x-transition:leave="transition ease-in duration-200"
			x-transition:leave-start="translate-y-0"
			x-transition:leave-end="translate-y-full"
			class="pointer-events-auto fixed inset-x-0 bottom-0 z-[60] max-h-[75vh] overflow-y-auto rounded-t-3xl border-t border-[var(--border-light)] bg-[var(--card-bg)] p-6 shadow-2xl"
			x-cloak
		>
			<div class="mb-6 flex items-center justify-between">
				<h3 class="text-lg font-bold text-[var(--text-main)]">{t('toc.mobile.button')}</h3>
				<button @click="tocOpen = false" class="rounded-full bg-[var(--primary-10)] p-2 text-[var(--primary)] transition-colors hover:bg-[var(--primary)] hover:text-white">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
				</button>
			</div>
			<div @click="tocOpen = false">
				<WidgetToc />
			</div>
		</div>
	</div>
</Layout>
