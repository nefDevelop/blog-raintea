---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const allSeries = await getCollection('series');
	return allSeries.map((s) => ({ params: { series: s.id }, props: s }));
}

const series = Astro.props;
const allPosts = await getCollection('blog');

const chapters = series.data.chapters
	.map((slug) => allPosts.find((p) => p.id === slug))
	.filter(Boolean)
	.map((post) => {
		const words = (post!.body || '').split(/\s+/g).filter(Boolean).length;
		const readingTime = `${Math.max(1, Math.ceil(words / 200))} min read`;
		return { ...post!, readingTime };
	});

const totalWords = chapters.reduce((sum, p) => sum + (p.body || '').split(/\s+/g).filter(Boolean).length, 0);
const totalMinutes = Math.max(1, Math.ceil(totalWords / 200));
---

<Layout title={`${series.data.title} — Series`} description={series.data.description}>
	<section class="mx-auto max-w-3xl px-4 py-12">
		{series.data.cover && (
			<img src={series.data.cover} alt="" class="mb-6 aspect-video w-full rounded-xl object-cover" />
		)}

		<div class="mb-8">
			<h1 class="text-3xl font-bold">{series.data.title}</h1>
			<p class="mt-1 text-[var(--text-muted)]">{series.data.description}</p>
			<div class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm text-[var(--text-muted)]">
				<span>{chapters.length} chapter{chapters.length !== 1 ? 's' : ''}</span>
				<span>{totalMinutes} min total</span>
				{series.data.author.length > 0 && <span>by {series.data.author.join(', ')}</span>}
			</div>
		</div>

		<div class="mb-8 h-2 w-full overflow-hidden rounded-full bg-[var(--border-light)]">
			<div class="h-full rounded-full bg-[var(--primary)] transition-all" style="width: 0%"></div>
		</div>

		<div class="space-y-4">
			{chapters.map((post, index) => (
				<a
					href={`/blog/${post.id}/`}
					class="flex items-start gap-4 rounded-xl border border-[var(--border-light)] bg-[var(--card-bg)] p-5 no-underline transition-shadow hover:shadow-sm"
				>
					<span class="flex size-8 shrink-0 items-center justify-center rounded-full bg-[var(--primary-90)] text-sm font-bold text-[var(--primary-10)]">
						{index + 1}
					</span>
					<div class="min-w-0 flex-1">
						<div class="text-xs text-[var(--primary)] font-medium">Chapter {index + 1}</div>
						<h2 class="text-lg font-semibold text-[var(--text-main)] hover:text-[var(--primary)]">{post.data.title}</h2>
						<p class="mt-0.5 text-sm text-[var(--text-muted)] line-clamp-1">{post.data.description}</p>
						<div class="mt-1 flex gap-2 text-xs text-[var(--text-muted)]">
							<FormattedDate date={post.data.published} />
							<span>{post.readingTime}</span>
						</div>
					</div>
				</a>
			))}
		</div>
	</section>
</Layout>