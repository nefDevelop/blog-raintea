---
import { getCollection } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

const docs = await getCollection('docs');
const sorted = docs.sort((a, b) => a.data.order - b.data.order);
const first = sorted[0];
---

<DocsLayout title="Docs" description="Documentation" entries={docs} hideShare>
	<h1 class="mb-4 text-3xl font-bold">Documentation</h1>
	<p class="text-[var(--text-muted)]">Select a topic from the sidebar to get started.</p>

	<div class="mt-8 grid gap-4 sm:grid-cols-2">
		{
			sorted.map((doc) => (
				<a
					href={`/docs/${doc.id}/`}
					class="block rounded-xl border border-[var(--border-light)] bg-[var(--card-bg)] p-5 no-underline transition-shadow hover:shadow-sm"
				>
					<h2 class="text-lg font-semibold text-[var(--text-main)]">{doc.data.title}</h2>
					<p class="mt-1 text-sm text-[var(--text-muted)]">{doc.data.description}</p>
				</a>
			))
		}
	</div>
</DocsLayout>
