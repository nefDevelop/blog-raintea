---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	return docs.map((doc) => ({
		params: { slug: doc.id },
		props: doc,
	}));
}

type Props = CollectionEntry<'docs'>;

const doc = Astro.props;
const docs = await getCollection('docs');
const { Content } = await render(doc);
---

<DocsLayout title={`${doc.data.title} — Docs`} description={doc.data.description} entries={docs} currentTitle={doc.data.title} currentSection={doc.data.section} currentSlug={doc.id}>
	<h1 class="mb-2 text-3xl font-bold">{doc.data.title}</h1>
	<p class="mb-2 text-[var(--text-muted)]">{doc.data.description}</p>
	{doc.data.updatedDate && (
		<p class="mb-8 text-xs text-[var(--text-muted)]">Updated <FormattedDate date={doc.data.updatedDate} /></p>
	)}
	<div class="prose">
		<Content />
	</div>
</DocsLayout>
