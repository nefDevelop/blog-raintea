---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Search" description="Search the site">
	<section class="mx-auto max-w-3xl px-4 py-12">
		<div class="mb-8 flex items-center justify-between">
			<div>
				<h1 class="text-3xl font-bold">Search</h1>
				<p class="mt-1 text-[var(--text-muted)]">Search across all content.</p>
			</div>
			<kbd class="hidden rounded-md border border-[var(--border-light)] px-2 py-1 text-xs text-[var(--text-muted)] sm:inline-block">Ctrl+K</kbd>
		</div>

		<div class="pagefind-ui" data-pagefind-ui x-init="$nextTick(() => { const i = $el.querySelector('input'); if (i) i.focus(); })"></div>

		<noscript>
			<p class="rounded-xl border border-[var(--border-light)] bg-[var(--card-bg)] p-5 text-sm text-[var(--text-muted)]">Search requires JavaScript to be enabled.</p>
		</noscript>
	</section>
</Layout>

<script is:inline>
	document.addEventListener('keydown', (e) => {
		if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
			e.preventDefault();
			const input = document.querySelector('.pagefind-ui input');
			if (input) input.focus();
		}
	});
</script>