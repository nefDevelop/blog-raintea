---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');
const allAuthors = await getCollection('authors');
const authorSlugs = [...new Set(posts.flatMap((p) => p.data.author))].sort();

const authors = authorSlugs.map((slug) => {
	const info = allAuthors.find((a) => a.id === slug);
	const count = posts.filter((p) => p.data.author.includes(slug)).length;
	return { slug, name: info?.data.name || slug, avatar: info?.data.avatar, bio: info?.data.bio, count };
});
---

<Layout title="Authors" description="All authors">
	<section class="mx-auto max-w-3xl px-4 py-12">
		<h1 class="mb-2 text-3xl font-bold">Authors</h1>
		<p class="mb-8 text-[var(--text-muted)]">Browse posts by author.</p>

		<div class="space-y-4">
			{authors.map((author) => (
				<a href={`/authors/${author.slug}/`} class="flex items-center gap-4 rounded-xl border border-[var(--border-light)] bg-[var(--card-bg)] p-5 no-underline transition-shadow hover:shadow-sm">
					{author.avatar ? (
						<img src={author.avatar} alt={author.name} class="size-14 rounded-full object-cover" />
					) : (
						<div class="flex size-14 items-center justify-center rounded-full bg-[var(--secondary-90)] text-lg font-bold text-[var(--secondary-10)]">
							{author.name[0]}
						</div>
					)}
					<div class="min-w-0 flex-1">
						<h2 class="text-lg font-semibold text-[var(--text-main)] group-hover:text-[var(--primary)]">{author.name}</h2>
						{author.bio && <p class="mt-0.5 text-sm text-[var(--text-muted)] line-clamp-2">{author.bio}</p>}
					</div>
					<span class="shrink-0 rounded-full bg-[var(--primary-90)] px-3 py-1 text-sm text-[var(--primary-10)]">{author.count} post{author.count !== 1 ? 's' : ''}</span>
				</a>
			))}
		</div>
	</section>
</Layout>