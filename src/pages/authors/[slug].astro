---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import Layout from '../../layouts/Layout.astro';
import Pagination from '../../components/Pagination.astro';
import GitHub from '../../components/icons/GitHub.astro';
import Twitter from '../../components/icons/Twitter.astro';

export async function getStaticPaths() {
	const PAGE_SIZE = 6;
	const posts = await getCollection('blog');
	const authors = [...new Set(posts.flatMap((p) => p.data.author))];
	const allAuthors = await getCollection('authors');
	const paths: {
		params: { slug: string | string[] };
		props: { authorName: string; authorInfo: any; posts: any[]; currentPage: number; lastPage: number; total: number };
	}[] = [];

	for (const slug of authors) {
		const info = allAuthors.find((a) => a.id === slug);
		const filtered = posts
			.filter((p) => p.data.author.includes(slug))
			.sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf())
			.map((post) => {
				const words = (post.body || '').split(/\s+/g).filter(Boolean).length;
				const readingTime = `${Math.max(1, Math.ceil(words / 200))} min read`;
				return { ...post, readingTime };
			});

		const lastPage = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
		for (let page = 1; page <= lastPage; page++) {
			const start = (page - 1) * PAGE_SIZE;
			paths.push({
				params: { slug: page === 1 ? slug : [slug, String(page)] },
				props: {
					authorName: info?.data.name || slug,
					authorInfo: info?.data || null,
					posts: filtered.slice(start, start + PAGE_SIZE),
					currentPage: page,
					lastPage,
					total: filtered.length,
				},
			});
		}
	}
	return paths;
}

const { authorName, authorInfo, posts, currentPage, lastPage, total } = Astro.props;
---

<Layout title={authorName} description={`Posts by ${authorName}`}>
	<section class="mx-auto max-w-3xl px-4 py-12">

		{authorInfo && (
			<div class="mb-10 flex items-start gap-6 rounded-xl border border-[var(--border-light)] bg-[var(--card-bg)] p-6">
				{authorInfo.avatar ? (
					<img src={authorInfo.avatar} alt={authorName} class="size-20 rounded-full object-cover" />
				) : (
					<div class="flex size-20 shrink-0 items-center justify-center rounded-full bg-[var(--secondary-90)] text-2xl font-bold text-[var(--secondary-10)]">
						{authorName[0]}
					</div>
				)}
				<div class="min-w-0 flex-1">
					<h1 class="text-2xl font-bold">{authorName}</h1>
					{authorInfo.bio && <p class="mt-1 text-sm text-[var(--text-muted)]">{authorInfo.bio}</p>}
					<p class="mt-1 text-sm text-[var(--text-muted)]">{total} post(s)</p>
					{(authorInfo.github || authorInfo.website || authorInfo.twitter) && (
						<div class="mt-3 flex gap-2">
							{authorInfo.github && (
								<a href={authorInfo.github} target="_blank" rel="noopener noreferrer" class="flex size-8 items-center justify-center rounded-md border border-[var(--border-light)] text-[var(--text-muted)] hover:text-[var(--primary)] transition-colors" aria-label="GitHub">
									<GitHub size={16} />
								</a>
							)}
							{authorInfo.twitter && (
								<a href={authorInfo.twitter} target="_blank" rel="noopener noreferrer" class="flex size-8 items-center justify-center rounded-md border border-[var(--border-light)] text-[var(--text-muted)] hover:text-[var(--primary)] transition-colors" aria-label="Twitter/X">
									<Twitter size={16} />
								</a>
							)}
							{authorInfo.website && (
								<a href={authorInfo.website} target="_blank" rel="noopener noreferrer" class="flex size-8 items-center justify-center rounded-md border border-[var(--border-light)] text-[var(--text-muted)] hover:text-[var(--primary)] transition-colors" aria-label="Website">
									<svg class="size-4 fill-none stroke-current stroke-2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>
								</a>
							)}
						</div>
					)}
				</div>
			</div>
		)}

		{!authorInfo && (
			<div class="mb-8">
				<h1 class="text-3xl font-bold capitalize">{authorName}</h1>
				<p class="text-[var(--text-muted)]">{total} post(s)</p>
			</div>
		)}

		<div class="space-y-6">
			{posts.map((post) => (
				<article class="rounded-xl border border-[var(--border-light)] bg-[var(--card-bg)] p-5">
					<a href={`/blog/${post.id}/`} class="no-underline">
						<h2 class="text-lg font-semibold text-[var(--text-main)] hover:text-[var(--primary)]">{post.data.title}</h2>
					</a>
					<p class="mt-1 text-sm text-[var(--text-muted)]">{post.data.description}</p>
					<div class="mt-2 flex gap-2 text-xs text-[var(--text-muted)]">
						<FormattedDate date={post.data.published} />
						<span>{post.readingTime}</span>
					</div>
				</article>
			))}
		</div>

		<Pagination currentPage={currentPage} lastPage={lastPage} baseUrl={`/authors/${authorName}/`} />
	</section>
</Layout>