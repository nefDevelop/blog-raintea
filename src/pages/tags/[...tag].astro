---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import Layout from '../../layouts/Layout.astro';
import Pagination from '../../components/Pagination.astro';
import { TAG_DESCRIPTIONS } from '../../consts';

export async function getStaticPaths() {
	function getHierarchicalTags(tags: string[]): string[] {
		const expanded = new Set<string>();
		tags.forEach((tag) => {
			const parts = tag.split('/');
			let current = '';
			parts.forEach((part, index) => {
				current = index === 0 ? part : `${current}/${part}`;
				expanded.add(current);
			});
		});
		return Array.from(expanded);
	}

	const PAGE_SIZE = 6;
	const posts = await getCollection('blog');
	const allTags = [...new Set(posts.flatMap((p) => getHierarchicalTags(p.data.tags || [])))];
	const paths: {
		params: { tag: string | string[] };
		props: { tagName: string; posts: any[]; currentPage: number; lastPage: number; total: number };
	}[] = [];

	for (const tag of allTags) {
		const tagged = posts
			.filter((p) => (p.data.tags || []).some((t) => t === tag || t.startsWith(tag + '/')))
			.sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf())
			.map((post) => {
				const words = (post.body || '').split(/\s+/g).filter(Boolean).length;
				const readingTime = `${Math.max(1, Math.ceil(words / 200))} min read`;
				return { ...post, readingTime };
			});

		const lastPage = Math.max(1, Math.ceil(tagged.length / PAGE_SIZE));
		for (let page = 1; page <= lastPage; page++) {
			const start = (page - 1) * PAGE_SIZE;
			paths.push({
				params: { tag: page === 1 ? tag : [tag, String(page)] },
				props: {
					tagName: tag,
					posts: tagged.slice(start, start + PAGE_SIZE),
					currentPage: page,
					lastPage,
					total: tagged.length,
				},
			});
		}
	}
	return paths;
}

const { tagName, posts, currentPage, lastPage, total } = Astro.props;
---

<Layout title={`#${tagName}`} description={`Posts tagged with ${tagName}`}>
	<section class="mx-auto max-w-3xl px-4 py-12">
		<div class="mb-8">
			<h1 class="text-3xl font-bold">#{tagName}</h1>
			{TAG_DESCRIPTIONS[tagName] && <p class="mt-1 text-sm text-[var(--text-muted)]">{TAG_DESCRIPTIONS[tagName]}</p>}
			<p class="text-[var(--text-muted)]">{total} post(s)</p>
		</div>

		<div class="space-y-6">
			{posts.map((post) => (
				<article class="rounded-xl border border-[var(--border-light)] bg-[var(--card-bg)] p-5">
					<a href={`/blog/${post.id}/`} class="no-underline">
						<h2 class="text-lg font-semibold text-[var(--text-main)] hover:text-[var(--primary)]">{post.data.title}</h2>
					</a>
					<p class="mt-1 text-sm text-[var(--text-muted)]">{post.data.description}</p>
					<div class="mt-2 flex gap-2 text-xs text-[var(--text-muted)]">
						<FormattedDate date={post.data.published} />
						<span>{post.readingTime}</span>
					</div>
				</article>
			))}
		</div>

		<Pagination currentPage={currentPage} lastPage={lastPage} baseUrl={`/tags/${tagName}/`} />
	</section>
</Layout>