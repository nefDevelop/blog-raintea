---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');
const categories = [...new Set(posts.flatMap((p) => p.data.categories))].sort();
---

<Layout title="Categories" description="All categories">
	<section class="mx-auto max-w-3xl px-4 py-12">
		<h1 class="mb-2 text-3xl font-bold">Categories</h1>
		<p class="mb-8 text-[var(--text-muted)]">Browse posts by category.</p>

		<div class="flex flex-wrap gap-3">
			{
				categories.map((cat) => {
					const count = posts.filter((p) => p.data.categories.includes(cat)).length;
					return (
						<a
							href={`/categories/${cat}/`}
							class="flex items-center rounded border border-[var(--primary-20)] bg-[var(--primary-10)] px-3 py-1.5 text-sm font-bold uppercase tracking-wider text-[var(--primary)] no-underline transition-colors hover:bg-[var(--primary)] hover:text-white group"
						>
							{cat}
							<span class="ml-2 rounded bg-[var(--card-bg)] px-1.5 py-0.5 text-[10px] font-bold text-[var(--text-main)] opacity-90 transition-colors group-hover:text-[var(--primary)]">{count}</span>
						</a>
					);
				})
			}
		</div>
	</section>
</Layout>
