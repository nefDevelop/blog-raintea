---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const posts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf());

const years = [...new Set(posts.map((p) => p.data.published.getFullYear()))].sort((a, b) => b - a);
---

<Layout title={t('archive.title')} description={t('archive.description')}>
	<section class="mx-auto max-w-3xl px-4 py-12">
		<h1 class="mb-2 text-3xl font-bold">{t('archive.title')}</h1>
		<p class="mb-8 text-[var(--text-muted)]">{t('archive.description')}</p>

		{posts.length === 0 && (
			<p class="py-12 text-center text-[var(--text-muted)]">{t('index.empty')}</p>
		)}

		<div class="space-y-12">
			{
				years.map((year) => (
					<div class="relative">
						<!-- Marcador de Año -->
						<div class="sticky top-24 z-10 flex items-center bg-[var(--bg)] py-2">
							<span class="rounded-full border-2 border-[var(--primary)] bg-[var(--bg)] px-4 py-1.5 text-sm font-bold tracking-widest text-[var(--primary)] shadow-sm">{year}</span>
						</div>
						
						<!-- Línea y Posts -->
						<div class="relative ml-5 mt-6 space-y-6 border-l border-[var(--border-light)] pb-4">
							{
								posts
									.filter((p) => p.data.published.getFullYear() === year)
									.map((post) => (
										<a
											href={`/blog/${post.id}/`}
											class="group relative ml-6 flex flex-col gap-2 rounded-xl border border-transparent p-4 no-underline transition-colors hover:border-[var(--border-light)] hover:bg-[var(--card-bg)] sm:ml-8 sm:flex-row sm:items-center sm:gap-3"
										>
											<!-- Punto en la línea de tiempo -->
											<div class="absolute -left-[30.5px] top-[26px] size-3 rounded-full border-2 border-[var(--border-light)] bg-[var(--bg)] transition-colors group-hover:border-[var(--primary)] group-hover:bg-[var(--primary)] sm:-left-[38.5px] sm:top-1/2 sm:-mt-1.5"></div>
											
											<!-- Metadatos -->
											<div class="flex shrink-0 items-center gap-3 text-sm tabular-nums text-[var(--text-muted)] sm:w-28">
												<span class="rounded bg-[var(--border-light)] px-2.5 py-1 text-xs font-medium text-[var(--text-main)] transition-colors group-hover:bg-[var(--primary-10)] group-hover:text-[var(--primary)]"><FormattedDate date={post.data.published} showYear={false} /></span>
											</div>
											
											<!-- Título -->
											<span class="text-lg font-semibold leading-tight text-[var(--text-main)] transition-colors group-hover:text-[var(--primary)]">
												{post.data.title}
											</span>
											
											<!-- Badges -->
											<div class="ml-auto hidden items-center gap-1.5 lg:flex">
												{post.data.categories?.length > 0 && (
													<span class="rounded bg-[var(--primary-10)] px-2 py-0.5 text-[9px] font-bold uppercase tracking-widest text-[var(--primary)]">
														{post.data.categories[0]}
													</span>
												)}
											</div>
										</a>
									))
							}
						</div>
					</div>
				))
			}
		</div>
	</section>
</Layout>
